# Copy to .env and edit. This is the only file you need to touch for a
# standard deployment -- docker-compose.yml feeds every variable below
# into both the litterae container (config templating, see
# docker/entrypoint.sh) and the caddy container (reverse-proxy hostnames).
#
# The defaults below work out of the box for local testing with no real
# DNS (mail.localtest.me / admin.localtest.me are a public wildcard that
# always resolves to 127.0.0.1). For a real deployment: point DNS at this
# host, change these to your real domains, and delete
# docker-compose.override.yml -- it forces self-signed local certs;
# without it Caddy requests real Let's Encrypt certs automatically.

MAIL_HOSTNAME=mail.localtest.me
ADMIN_HOSTNAME=admin.localtest.me

# HELO/DKIM domain.
LITTERAE_DOMAIN=example.test

# Applied once on first startup if no admin exists yet -- log in and
# change the password, then these two stop mattering (re-adding them
# later is a no-op; bootstrap only ever fires once).
LITTERAE_ADMIN_USERNAME=admin
LITTERAE_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_UNIQUE_PASSWORD

# Only needed when running `npm run dev` against a JMAP backend that
# ISN'T reverse-proxied on the same origin (e.g. a bare `cargo run`
# backend on a different port during frontend-only development). The
# Docker Compose deployment doesn't need this at all -- Caddy serves this
# app and proxies /auth/*, /jmap/* to litterae from one origin.
VITE_JMAP_URL=http://localhost:8620
